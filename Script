local function MakeFloatDraggable(frame, name, onClickCallback, moveTarget)
    local dragging = false
    local dragInput, dragStart, startPos
    local wasDragged = false
    local target = moveTarget or frame
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            wasDragged = false
            dragStart = input.Position
            startPos = target.Position
            dragInput = input
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if not dragging then return end
        if input ~= dragInput then return end
        if uiLocked then return end
        local delta = input.Position - dragStart
        if delta.Magnitude > 6 then wasDragged = true end
        target.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        floatBtnPositions[name] = {
            xs = target.Position.X.Scale,
            xo = target.Position.X.Offset,
            ys = target.Position.Y.Scale,
            yo = target.Position.Y.Offset
        }
        saveFloatPositions()
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input == dragInput then
            dragging = false
            if not wasDragged and onClickCallback then onClickCallback() end
            wasDragged = false
        end
    end)
end

