-- [[ BUILD TABS ]]
local function buildTab(tabName)
    for _, child in pairs(scrollFrame:GetChildren()) do
        if child:IsA("GuiObject") then child:Destroy() end
    end

    if tabName == "Combat" then
        makeSwitch("Auto Grab", SETTINGS.ENABLED, function(on)
            SETTINGS.ENABLED = on
            if not on then resetBar() end
            autoSave()
        end)
        makeSwitch("TP Auto", tpAutoEnabled, function(on)
            tpAutoEnabled = on
            if setTpAutoBtn then setTpAutoBtn(on) end
            autoSave()
        end)
        makeSwitch("Auto Bat", false, function(on)
            if on then enableAutoBat() else disableAutoBat() end
            autoSave()
        end)

    elseif tabName == "Player" then
        makeSwitch("Float", SETTINGS.FLOAT, function(on)
            SETTINGS.FLOAT = on
            if not on and floatPart then floatPart:Destroy(); floatPart = nil end
            autoSave()
        end)
        makeSwitch("Unwalk", SETTINGS.UNWALK, function(on)
            SETTINGS.UNWALK = on
            autoSave()
        end)
        makeSwitch("Inf Jump", infJumpEnabled, function(on)
            infJumpEnabled = on
            autoSave()
        end)
        makeSwitch("Anti Ragdoll", false, function(on)
            if on then
                if not Connections.antiRagdoll then startAntiRagdoll() end
            else
                if Connections.antiRagdoll then
                    Connections.antiRagdoll:Disconnect()
                    Connections.antiRagdoll = nil
                end
            end
            autoSave()
        end)

    elseif tabName == "Visual" then
        makeSwitch("Player ESP", false, function(on)
            if on then enableESP() else disableESP() end
            autoSave()
        end)
        makeSwitch("Optimizer", false, function(on)
            if on then
                pcall(function()
                    workspace.Terrain.WaterWaveSize = 0
                    game:GetService("Lighting").GlobalShadows = false
                    for _, obj in pairs(game:GetDescendants()) do
                        if obj:IsA("BasePart") then obj.Material = Enum.Material.Plastic
                        elseif obj:IsA("Decal") then obj.Transparency = 1 end
                    end
                end)
            end
            autoSave()
        end)
        makeSwitch("Xray Base", false, function(on)
            if on then enableXrayBase() else disableXrayBase() end
            autoSave()
        end)

    elseif tabName == "Settings" then
        makeSwitch("Lock UI Position", uiLocked, function(on)
            uiLocked = on
            SETTINGS.UI_LOCKED = on
            autoSave()
        end)
        if isProtected then
            makeSwitch("Freeze", false, function(on)
                workspace:SetAttribute("CH_FREEZE", on)
                autoSave()
            end)
        end
    end
end

