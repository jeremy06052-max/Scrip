end

local function updateWalkFling()
walkFlingBtn.Text = walkFlingOn and “WALK FLING: ON” or “WALK FLING: OFF”
walkFlingBtn.BackgroundColor3 = walkFlingOn and Color3.fromRGB(160, 32, 240) or Color3.fromRGB(45, 0, 70)
end

– Toggles
fovBtn.MouseButton1Click:Connect(function()
fovOn = not fovOn
camera.FieldOfView = fovOn and 100 or 70
fovBtn.Text = fovOn and “FOV: ON” or “FOV: OFF”
fovBtn.BackgroundColor3 = fovOn and Color3.fromRGB(160, 32, 240) or Color3.fromRGB(45, 0, 70)
end)

galaxyBtn.MouseButton1Click:Connect(function()
galaxyOn = not galaxyOn
updateGalaxy()
end)

walkFlingBtn.MouseButton1Click:Connect(function()
walkFlingOn = not walkFlingOn
updateWalkFling()
walkFling(walkFlingOn)
end)

– Save Config
saveBtn.MouseButton1Click:Connect(function()
if writefile then
local data = {
FOV = fovOn, Galaxy = galaxyOn, WalkFling = walkFlingOn,
PosX = mainFrame.Position.X.Scale, OffsetX = mainFrame.Position.X.Offset,
PosY = mainFrame.Position.Y.Scale, OffsetY = mainFrame.Position.Y.Offset
}
writefile(FILE_NAME, HttpService:JSONEncode(data))
saveBtn.Text = “SAVED!”
task.wait(0.5)
saveBtn.Text = “SAVE CONFIG”
end
end)

– Load Config
if isfile and isfile(FILE_NAME) then
local s, d = pcall(function() return HttpService:JSONDecode(readfile(FILE_NAME)) end)
if s and d then
if d.PosX then mainFrame.Position = UDim2.new(d.PosX, d.OffsetX, d.PosY, d.OffsetY) end
fovOn      = d.FOV       or false
galaxyOn   = d.Galaxy    or false
walkFlingOn= d.WalkFling or false
if fovOn then camera.FieldOfView = 100; fovBtn.Text = “FOV: ON”; fovBtn.BackgroundColor3 = Color3.fromRGB(160, 32, 240) end
if walkFlingOn then walkFling(true) end
updateGalaxy()
updateWalkFling()
end
end
