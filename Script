-- [[ WALK FLING ]]
local _wfConns = {}
local _wfActive = false

local function startWalkFling()
    _wfActive = true
    table.insert(_wfConns, RunService.Stepped:Connect(function()
        if not _wfActive then return end
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                for _, part in ipairs(p.Character:GetChildren()) do
                    if part:IsA("BasePart") then part.CanCollide = false end
                end
            end
        end
    end))
    local co = coroutine.create(function()
        while _wfActive do
            RunService.Heartbeat:Wait()
            local char = LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not root then RunService.Heartbeat:Wait(); continue end
            local vel = root.Velocity
            root.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)
            RunService.RenderStepped:Wait()
            if root and root.Parent then root.Velocity = vel end
            RunService.Stepped:Wait()
            if root and root.Parent then root.Velocity = vel + Vector3.new(0, 0.1, 0) end
        end
    end)
    coroutine.resume(co)
    table.insert(_wfConns, co)
end

local function stopWalkFling()
    _wfActive = false
    for _, c in ipairs(_wfConns) do
        if typeof(c) == "RBXScriptConnection" then
            c:Disconnect()
        elseif typeof(c) == "thread" then
            pcall(task.cancel, c)
        end
    end
    _wfConns = {}
end

-- [[ PLOT DETECTION ]]
local function getMyPlot()
    for plotNum, position in pairs({[3] = PLOT3_POS, [7] = PLOT7_POS}) do
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Name == "PlotSign" then
                if (obj.Position - position).Magnitude < 1 then
                    for _, child in ipairs(obj:GetDescendants()) do
                        if child:IsA("SurfaceGui") then
                            for _, label in ipairs(child:GetDescendants()) do
                                if label:IsA("TextLabel") and label.Text ~= "" and
                                    (string.find(label.Text, LocalPlayer.Name) or
                                     string.find(label.Text, LocalPlayer.DisplayName)) then
                                    return plotNum
                                end
                            end
                        end
                    end
                end
            end
        end
    end
    return nil
end

local setAutoLeftState, setAutoRightState

local function doAutoTp(char)
    if not tpAutoEnabled then return end
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local plot = getMyPlot()
    if not plot then return end
    hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    if plot == 3 then
        hrp.CFrame = CFrame.new(CHECKPOINT_A); task.wait(0.1)
        hrp.CFrame = CFrame.new(CHECKPOINT_B1); task.wait(0.1)
        hrp.CFrame = CFrame.new(FINAL_POS1)
    elseif plot == 7 then
        hrp.CFrame = CFrame.new(CHECKPOINT_A); task.wait(0.1)
        hrp.CFrame = CFrame.new(CHECKPOINT_B2); task.wait(0.1)
        hrp.CFrame = CFrame.new(FINAL_POS2)
    end
    local waited = 0
    while not isStealing and waited < 3 do
        task.wait(0.02); waited += 0.02
    end
    while isStealing do task.wait(0.02) end
    task.wait(0.02)
    if plot == 3 then
        if SETTINGS.AUTOLEFT then
            SETTINGS.AUTOLEFT = false
            if setAutoLeftState then setAutoLeftState(false) end
            LeftPhase = 1; LeftStartPos = nil
        end
        RightPhase = 1; RightStartPos = nil
        SETTINGS.AUTORIGHT = true
        if setAutoRightState then setAutoRightState(true) end
    elseif plot == 7 then
        if SETTINGS.AUTORIGHT then
            SETTINGS.AUTORIGHT = false
            if setAutoRightState then setAutoRightState(false) end
            RightPhase = 1; RightStartPos = nil
        end
        LeftPhase = 1; LeftStartPos = nil
        SETTINGS.AUTOLEFT = true
        if setAutoLeftState then setAutoLeftState(true) end
    end
end

local function hookHumanoid(char)
    local hum = char:WaitForChild("Humanoid")
    hum.StateChanged:Connect(function(_, newState)
        if newState == Enum.HumanoidStateType.Physics or
            newState == Enum.HumanoidStateType.Ragdoll or
            newState == Enum.HumanoidStateType.FallingDown then
            task.spawn(doAutoTp, char)
        end
    end)
end

-- [[ ANTI RAGDOLL ]]
local function startAntiRagdoll()
    if Connections.antiRagdoll then return end
    Connections.antiRagdoll = RunService.Heartbeat:Connect(function()
        local char = LocalPlayer.Character
        if not char then return end
        local root = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            local humState = hum:GetState()
            if humState == Enum.HumanoidStateType.Physics or
                humState == Enum.HumanoidStateType.Ragdoll or
                humState == Enum.HumanoidStateType.FallingDown then
                hum:ChangeState(Enum.HumanoidStateType.Running)
                workspace.CurrentCamera.CameraSubject = hum
                pcall(function()
                    if LocalPlayer.Character then
                        local PlayerModule = LocalPlayer.PlayerScripts:FindFirstChild("PlayerModule")
                        if PlayerModule then
                            local Controls = require(PlayerModule:FindFirstChild("ControlModule"))
                            Controls:Enable()
                        end
                    end
                end)
                if root then
                    root.Velocity = Vector3.new(0, 0, 0)
                    root.RotVelocity = Vector3.new(0, 0, 0)
                end
            end
        end
        for _, obj in ipairs(char:GetDescendants()) do
            if obj:IsA("Motor6D") and obj.Enabled == false then obj.Enabled = true end
        end
    end)
    if LocalPlayer.Character then
        task.spawn(hookHumanoid, LocalPlayer.Character)
    end
    LocalPlayer.CharacterAdded:Connect(function(char)
        char:WaitForChild("HumanoidRootPart")
        task.wait(0.1)
        hookHumanoid(char)
    end)
end

